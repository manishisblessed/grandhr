# Server
PORT=5000
NODE_ENV=development

# MongoDB (required for login and all app features)
# Local: mongodb://localhost:27017/grandhr
# Atlas: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/grandhr?retryWrites=true&w=majority
DATABASE_URL="mongodb://localhost:27017/grandhr"

# JWT (generate a random string: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_SECRET
JWT_EXPIRES_IN=7d

# CORS (comma-separated origins). Use * to allow all (e.g. for mobile app).
# Example: https://grandhr.in,https://www.grandhr.in
CORS_ORIGIN=*

# Frontend URL (for password reset / email links)
FRONTEND_URL=http://localhost:3000

# Optional: Email (for forgot password, invites)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=noreply@grandhr.in

# Optional: Cloudinary (for document/file uploads)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
