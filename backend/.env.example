# GrandHR backend environment.
# Copy to `.env` and fill in real values. NEVER commit .env to git.

# ---- Runtime ---------------------------------------------------------------
NODE_ENV=development
PORT=5000

# ---- Database (Neon Postgres) ---------------------------------------------
# Pooled connection used by the app at runtime.
DATABASE_URL=postgresql://USER:PASS@HOST.neon.tech/grandhr?sslmode=require
# Direct connection used by Prisma migrations only.
DIRECT_URL=postgresql://USER:PASS@HOST.neon.tech/grandhr?sslmode=require

# ---- Auth -----------------------------------------------------------------
# Use `openssl rand -hex 48` to generate. MUST be >=16 chars; placeholder
# values like "secret" are rejected at boot in production.
JWT_SECRET=replace-me-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# ---- HTTP / CORS ----------------------------------------------------------
# Comma-separated list of allowed frontend origins. No wildcard in production.
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,https://grandhr.in,https://www.grandhr.in
FRONTEND_URL=https://grandhr.in

# ---- Email (Gmail App Password or SMTP relay) -----------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=hello@grandhr.in
SMTP_PASS=app-specific-password
EMAIL_FROM="GrandHR <hello@grandhr.in>"

# ---- Cloudinary (file uploads) --------------------------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---- Web Push (VAPID) -----------------------------------------------------
# Generate once with:  npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:noreply@grandhr.in

# ---- Razorpay (billing) ---------------------------------------------------
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ---- Observability (optional) ---------------------------------------------
# When set, server errors are reported to Sentry.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
