# All variables prefixed EXPO_PUBLIC_* are baked into the client bundle at build
# time. Never put real secrets here.
#
# For EAS builds, use: eas env:create --name EXPO_PUBLIC_API_URL

# --- API ---
# Production default is https://api.grandhr.in/api.
EXPO_PUBLIC_API_URL=https://api.grandhr.in/api

# --- Feature flags ---
# Enable the "Register your company" flow on the Login screen. Keep FALSE for
# enterprise / MNC builds where users are provisioned by their admin.
EXPO_PUBLIC_ALLOW_COMPANY_SIGNUP=false

# Optional customer-support WhatsApp number (digits only, with country code, e.g.
# 441234567890). Leave empty to hide the WhatsApp support option entirely.
EXPO_PUBLIC_SUPPORT_WHATSAPP=

# Customer-support email shown in Settings / About.
EXPO_PUBLIC_SUPPORT_EMAIL=support@grandhr.in

# Public URLs surfaced in-app (Settings, registration consent). These MUST
# match what is listed on Google Play Data Safety and in App Store Connect.
EXPO_PUBLIC_PRIVACY_URL=https://grandhr.in/privacy-policy
EXPO_PUBLIC_TERMS_URL=https://grandhr.in/terms
EXPO_PUBLIC_ACCOUNT_DELETION_URL=https://grandhr.in/account-deletion

# Auto-sign-out after N minutes of inactivity. Default 15.
EXPO_PUBLIC_IDLE_LOGOUT_MINUTES=15

# Force users to enable biometric app lock. Default false (user choice).
EXPO_PUBLIC_REQUIRE_APP_LOCK=false

# --- Observability ---
# Optional Sentry DSN. If unset, telemetry is a no-op.
EXPO_PUBLIC_SENTRY_DSN=
