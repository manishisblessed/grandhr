{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": { "simulator": true },
      "android": { "buildType": "apk" },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.grandhr.in/api",
        "EXPO_PUBLIC_ALLOW_COMPANY_SIGNUP": "true"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": { "simulator": false },
      "android": { "buildType": "apk" },
      "channel": "preview",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.grandhr.in/api",
        "EXPO_PUBLIC_ALLOW_COMPANY_SIGNUP": "false"
      }
    },
    "production": {
      "channel": "production",
      "autoIncrement": true,
      "ios": { "autoIncrement": "buildNumber" },
      "android": {
        "autoIncrement": "versionCode",
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.grandhr.in/api",
        "EXPO_PUBLIC_ALLOW_COMPANY_SIGNUP": "false",
        "EXPO_PUBLIC_IDLE_LOGOUT_MINUTES": "15"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json",
        "track": "production"
      },
      "ios": {
        "appleId": "$EXPO_APPLE_ID",
        "ascAppId": "$EXPO_ASC_APP_ID",
        "appleTeamId": "$EXPO_APPLE_TEAM_ID"
      }
    },
    "internal": {
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json",
        "track": "internal"
      },
      "ios": {
        "appleId": "$EXPO_APPLE_ID",
        "ascAppId": "$EXPO_ASC_APP_ID",
        "appleTeamId": "$EXPO_APPLE_TEAM_ID"
      }
    }
  }
}
