{
  "expo": {
    "name": "GrandHR - HR Management",
    "slug": "grandhr-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "grandhr",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#4F46E5"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "privacy": "https://grandhr.in/privacy-policy",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.grandhr.mobile",
      "buildNumber": "1",
      "infoPlist": {
        "CFBundleAllowMixedLocalizations": true
      },
      "config": {
        "usesNonExemptEncryption": false
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": [
              "CA92.1"
            ]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4F46E5"
      },
      "package": "com.grandhr.mobile",
      "versionCode": 1,
      "permissions": [
        "INTERNET"
      ],
      "blockedPermissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "extra": {
      "apiUrl": "https://api.grandhr.in/api",
      "eas": {
        "projectId": "cdb49779-1f5d-452f-8593-386c311d1ff9"
      }
    },
    "plugins": [
      "expo-secure-store",
      "expo-font"
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/cdb49779-1f5d-452f-8593-386c311d1ff9",
      "fallbackToCacheTimeout": 0
    },
    "owner": "shahworks"
  }
}
