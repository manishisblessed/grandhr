        "backgroundColor": "#4F46E5"
      },
      "package": "com.grandhr.mobile"
    },
    "extra": {
      "apiUrl": "http://3.82.65.130:5000/api",
      "eas": {
        "projectId": "eb4ea9be-7b0d-46fc-942b-f1848e9fe49a"
      }
    },
    "plugins": [
      "expo-secure-store",
      "expo-font"
    ],
    "owner": "grandhr",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/eb4ea9be-7b0d-46fc-942b-f1848e9fe49a"
    }
  }
