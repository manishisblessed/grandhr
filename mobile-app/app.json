{
  "expo": {
    "name": "GrandHR",
    "slug": "grandhr-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#4F46E5"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.grandhr.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4F46E5"
      },
      "package": "com.grandhr.mobile"
    },
    "extra": {
      "apiUrl": "https://api.grandhr.in/api",
      "eas": {
        "projectId": "f1f7cd5c-bcf1-468b-bbb8-854765cd84e1"
      }
    },
    "plugins": [
      "expo-secure-store",
      "expo-font"
    ],
    "owner": "manishisspecial",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/f1f7cd5c-bcf1-468b-bbb8-854765cd84e1"
    }
  }
}
